{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Read(*)",
      "Write(.claude/**)",
      "Write(main/docs/**)",
      "Write(main/backend/**)",
      "Write(main/frontend/**)",
      "Write(main/tests/**)",
      "Write(main/examples/**)",
      "Edit(*)",
      "Grep(*)",
      "Glob(*)",
      "Skill(*)",
      "Task(*)",
      "TodoWrite"
    ],
    "ask": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(rm:*)",
      "Bash(docker:*)"
    ],
    "deny": [
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Read(.git/**)",
      "Write(.git/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)"
    ],
    "defaultMode": "acceptEdits",
    "additionalDirectories": []
  },
  "attribution": {
    "commit": "🤖 Generated by Claude Dev Team v3.0 - LLM-Driven Intelligent Collaboration",
    "pr": "🤖 Claude Dev Team v3.0 - Fully LLM-driven AI collaboration with autonomous evolution"
  },
  "cleanupPeriodDays": 30,
  "outputStyle": "default",
  "model": "sonnet",
  "env": {},
  "respectGitignore": true,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/quality-gate.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/path_validator.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/safety-check.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/context-enhancer.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/session_evolver.py",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/strategy_updater.py",
            "timeout": 30
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/auto_evolver.py",
            "timeout": 25
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/setup_env.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "llm_driven_config": {
    "intelligent_analysis_enabled": true,
    "autonomous_evolution_enabled": true,
    "real_time_collaboration_enabled": true,
    "predictive_optimization_enabled": true,
    "context_driven_learning": true
  }
}
